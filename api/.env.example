# slicd-api configuration (copy to slicd-api.env in the stack; *.env is gitignored)

# Seerr (identity + search)
SEERR_URL=https://request.internal
SEERR_API_KEY=
SEERR_VERIFY_SSL=false

# Servarr release-date sources
RADARR_URL=http://10.10.10.60:30025
RADARR_API_KEY=
SONARR_URL=http://10.10.10.60:30113
SONARR_API_KEY=
ANIME_URL=http://10.10.10.60:30114
ANIME_API_KEY=

# Auth / sessions
SECRET_KEY=            # long random string; signs session cookies
PLEX_CLIENT_ID=        # stable UUID, the app's X-Plex-Client-Identifier
PLEX_PRODUCT=Slicd
SESSION_SECURE=true
# DEV_PLEX_ID=         # dev only: bypass OAuth via X-Dev-Plex-Id header

# Front-end origin(s) for CORS
CORS_ORIGINS=https://calendar.happysofa.org,https://calendar.internal
